# Minimal .gitignore for Railway deployment with PostgreSQL
# Only include essential files

# Ignore everything by default
*

# But keep these essential files for Railway
!main.py
!railway_app.py
!2025_hackathon.py
!email_tracker.py
!dump_email_tracking.py
!query_database.py
!requirements.txt
!Procfile
!runtime.txt
!.gitignore

# Keep documentation
!README.md
!SETUP.md
!MAINTENANCE.md
!REFACTORING.md
!STRUCTURE.md

# Keep configuration
!config.py
!workato_reply_schema.json

# Keep modular structure
!models/
!models/**
!services/
!services/**
!routes/
!routes/**
!utils/
!utils/**
!templates/
!templates/**

# Ignore virtual environments
flask_env/
yodavenv/
venv/
env/
.venv/

# Ignore Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore database files
*.db
*.sqlite
*.sqlite3

# Ignore sensitive files
.env
*.env
credentials.json
token.pickle
